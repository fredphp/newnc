  config_dog_high_food_life     Int      @default(10)
  config_auto_harvest_time      Int      @default(1)
  config_auto_seed_time         Int      @default(1)
  config_luck_active_pro        String?  @db.VarChar(11) @default("10")
  config_luck_add_pro           String?  @db.VarChar(11) @default("10")
  config_dog_food_rose_exp      String?  @db.VarChar(11) @default("0")
  config_dog_high_food_rose_exp String?  @db.VarChar(11) @default("0")
  config_pet_drill_rose_exp     String?  @db.VarChar(11) @default("10")
  config_special_exp            String?  @db.VarChar(11) @default("1000")
  config_pet_food_attribute     String?  @db.VarChar(11) @default("6")
  config_diamond_first          String?  @db.VarChar(11) @default("0")
  config_diamond_second         String?  @db.VarChar(11) @default("200")
  config_diamond_third          String?  @db.VarChar(11) @default("2000")
  config_diamond_give           String?  @db.VarChar(11) @default("25")
  config_diamond_recharge       String?  @db.VarChar(11) @default("1")
  config_diamond_one            String?  @db.VarChar(11) @default("1")
  config_diamond_two            String?  @db.VarChar(11) @default("0")
  config_diamond_three          String?  @db.VarChar(11) @default("0")
  config_rmb_gold               String?  @db.VarChar(11) @default("1")
  config_open_time              String?  @db.VarChar(10) @default("09:00:00")
  config_close_time             String?  @db.VarChar(10) @default("23:00:00")
  config_limit_up               String?  @db.VarChar(11) @default("50")
  config_limit_down             String?  @db.VarChar(11) @default("50")
  config_trade_cost             String?  @db.VarChar(11) @default("0.01")
  config_set_open_price         String?  @db.VarChar(11) @default("0.01")
  config_seed_open_price        String?  @db.VarChar(11) @default("0.01")

