// ==================== 宠物列表 ====================
model PetList {
  id              Int      @id @default(autoincrement())
  pet_name        String?  @db.VarChar(255)
  pet_score       String?  @db.VarChar(255)
  pet_identifier  String?  @db.VarChar(255)
  pet_attack      String?  @db.VarChar(255)
  pet_defense     String?  @db.VarChar(255)
  pet_speed       String?  @db.VarChar(255)
  pet_luck        String?  @db.VarChar(255)
  pet_life        String?  @db.VarChar(255)
  pet_description String?  @db.VarChar(255)

  @@map("think_pet_list")
}

// ==================== 房屋列表 ====================
model HouseList {
  id               Int      @id @default(autoincrement())
  house_name       String?  @db.VarChar(255)
  house_level      String?  @db.VarChar(255)
  house_info       String?  @db.VarChar(255)
  house_description String? @db.VarChar(255)

  @@map("think_house_list")
}

// ==================== 游戏记录 ====================
model GameRecord {
  id            Int       @id @default(autoincrement())
  userid        Int?
  username      String?   @db.VarChar(255)
  game_time     DateTime? @db.DateTime
  recharge      Int?
  recharge_money Int?
  fc            Int?

  @@map("think_game_record")
}

// ==================== 商店分类 ====================
model ShopClassList {
  id        Int      @id @default(autoincrement())
  name      String?  @db.VarChar(255)
  sort      Int      @default(0)
  status    Int      @default(1)

  @@map("think_shop_class_list")
}

// ==================== 商店商品 ====================
model ShopCommodityList {
  id            Int       @id @default(autoincrement())
  name          String?   @db.VarChar(255)
  classid       Int?
  price         Int?
  originalPrice Int?
  inventory     Int?
  sales         Int?
  pic           String?   @db.VarChar(255)
  status        Int       @default(1)
  description   String?   @db.Text
  sort          Int       @default(0)

  @@map("think_shop_commodity_list")
}

// ==================== 签到记录 ====================
model SignRecord {
  id        Int       @id @default(autoincrement())
  userid    Int
  username  String?   @db.VarChar(50)
  time      DateTime? @db.DateTime
  type      Int       @default(1)

  @@map("think_sign_record")
}

// ==================== 文章分类 ====================
model ArticleClass {
  id        Int      @id @default(autoincrement())
  classname String   @unique @db.VarChar(30)

  @@map("think_articleclass")
}

// ==================== 文章表 ====================
model Article {
  id            Int       @id @default(autoincrement())
  author        String    @db.Char(30)
  releasetime   Int
  modifiedtime  Int
  title         String    @db.VarChar(50)
  content       String    @db.Text
  browsenum     Int
  classid       Int

  @@map("think_article")
}

// ==================== 系统配置 ====================
model Sys {
  id        Int      @id @default(autoincrement())
  name      String?  @db.VarChar(255)
  value     String?  @db.Text

  @@map("think_sys")
}

// ==================== 系统信息 ====================
model SysInfo {
  id        Int      @id @default(autoincrement())
  name      String?  @db.VarChar(255)
  value     String?  @db.Text

  @@map("think_sysinfo")
}

// ==================== 公告表 ====================
model Notice {
  id        Int       @id @default(autoincrement())
  title     String?   @db.VarChar(255)
  content   String?   @db.Text
  time      DateTime? @db.DateTime
  status    Int       @default(1)

  @@map("think_notice")
}
